# -----------------------------------------------------------------------------
# 核心与安全配置
# -----------------------------------------------------------------------------

# API 访问密钥（客户端请求需在 x-api-key 请求头中传递此值）
PEANUT_API_SECRET=your-strong-secret-key-here

# 生产环境标记 (true: 生产环境, false: 开发环境)
PEANUT_PRODUCTION=false

# 数据库文件路径（默认存放在当前目录的 timeline.db）
# PEANUT_DB_FILE=/path/to/custom/timeline.db

# -----------------------------------------------------------------------------
# 资源与网络配置
# -----------------------------------------------------------------------------

# 上传图片及视频的保存目录路径
# PEANUT_UPLOAD_DIR=/path/to/custom/uploads

# 站点的基础 URL，用于生成上传文件的完整链接（包含协议和域名）
# 生产环境强烈推荐配置！例如：https://api.example.com
PEANUT_BASE_URL=

# CORS 跨域白名单（多个域名用逗号分隔，不支持通配符 *）
# 如果不填，默认只允许 localhost 和 127.0.0.1 (见 config.php 中的默认配置)
PEANUT_CORS_ALLOWED_ORIGINS=https://hetao.us,https://admin.hetao.us,https://duanxinyu.hetao.us

# 是否在外部 HTTPS 请求中开启 SSL 证书校验 (true/false)
PEANUT_SSL_VERIFY=true

# -----------------------------------------------------------------------------
# 媒体与第三方服务
# -----------------------------------------------------------------------------

# 生成缩略图的最大宽度（像素）
PEANUT_THUMB_MAX_WIDTH=800

# 生成缩略图的质量（1-100，100为最好质量且体积最大）
PEANUT_THUMB_QUALITY=60

# 高德地图 Web 服务 API Key
# 用于解析照片的经纬度并返回中文地址
PEANUT_AMAP_KEY=your-amap-key-here
